<button class="booking-btn" @onclick="HandleBookingClick">
    <span class="booking-btn__text">Book an Appointment</span>
    <span class="booking-btn__icon">→</span>
</button>

<BookingModal @bind-IsOpen="showBookingModal" OnBook="OnBooked" />

@code {
    private bool showBookingModal;

    private void HandleBookingClick()
    {
        showBookingModal = true;
    }

    private Task OnBooked()
    {
        Console.WriteLine("Booking submitted.");
        return Task.CompletedTask;
    }
}