@page "/book/{Category}"
@inject IAppDbOperator AppDbOperator
@inject IAppEmailer    AppEmailer

<PageTitle>Book Service</PageTitle>

@if (IsLoading)
{
    <div class="container py-5 text-center">
        <div class="spinner-border text-secondary"></div>
        <p class="text-muted mt-3">Loading service details...</p>
    </div>
}
else if (SelectedService is null)
{
    <div class="container py-5">
        <div class="alert alert-warning rounded-4 border-0 shadow-sm">
            <h4 class="fw-bold">Service not found</h4>
            <p class="mb-0">The selected service does not exist.</p>
        </div>
    </div>
}
else
{
    <section class="py-5">
        <div class="container py-4">
            <div class="booking-shell">
                <div class="mb-4">
                    <a href="/" class="btn btn-light rounded-pill px-4 mb-3 shadow-sm">
                        ← Back to categories
                    </a>

                    <span class="section-badge text-uppercase">@Category</span>
                    <h1 class="fw-bold mt-3 booking-page-title">Book @GetCategoryDisplayName() Appointment</h1>
                    <p class="text-muted booking-page-subtitle">
                        Choose one or more services below, select an available schedule, and continue to your client details.
                    </p>
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="alert alert-danger rounded-4">@ErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(SuccessMessage))
                {
                    <div class="alert alert-success rounded-4">@SuccessMessage</div>
                }

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="row g-4">
                            @foreach (var service in CurrentCategoryServices)
                            {
                                var availableDates = GetAvailableDates(service);
                                var selectedDate = GetSelectedDate(service.Uid);
                                var selectedTime = GetSelectedTime(service.Uid);
                                var isAlreadyAdded = AppointmentItems.Any(x => x.ServiceUid == service.Uid);

                                <div class="col-12">
                                    <div class="card border-0 shadow-sm rounded-4 @(service.Uid == SelectedService.Uid ? "border border-2 border-dark" : "")">
                                        <div class="card-body p-4">
                                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                                <div>
                                                    <h4 class="fw-bold mb-1">@service.Details</h4>
                                                    <div class="text-muted small">Service Code: @service.Uid</div>
                                                </div>
                                                <div class="text-end">
                                                    <div class="fw-semibold">₱@service.Cost</div>
                                                    <div class="small text-muted">
                                                        @(service.ScheduleSlots?.IsAvailable == true ? "Available" : "Unavailable")
                                                    </div>
                                                </div>
                                            </div>

                                            <hr />

                                            <div class="mb-3">
                                                <div>
                                                    <strong>Available Days:</strong>
                                                    @(service.ScheduleSlots?.DaySlots is { Count: > 0 }
                                                                                                ? string.Join(", ", service.ScheduleSlots.DaySlots)
                                                                                                : "No days available")
                                                </div>
                                                <div>
                                                    <strong>Available Times:</strong>
                                                    @(service.ScheduleSlots?.TimeSlots is { Count: > 0 }
                                                                                                ? string.Join(", ", service.ScheduleSlots.TimeSlots)
                                                                                                : "No time slots available")
                                                </div>
                                            </div>

                                            @if (service.ScheduleSlots?.IsAvailable != true || availableDates.Count == 0)
                                            {
                                                <div class="alert alert-warning rounded-4 mb-0">
                                                    This service currently has no bookable schedule.
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Choose date</label>
                                                        <select class="form-select"
                                                                value="@GetSelectedDateString(service.Uid)"
                                                                @onchange="(e) => OnDateChanged(service.Uid, e.Value?.ToString())">
                                                            <option value="">Select a date</option>
                                                            @foreach (var date in availableDates)
                                                            {
                                                                <option value="@date.ToString("yyyy-MM-dd")">
                                                                    @date.ToString("MMMM dd, yyyy (dddd)")
                                                                </option>
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label fw-semibold">Choose time</label>
                                                        <select class="form-select"
                                                                value="@selectedTime"
                                                                @onchange="(e) => OnTimeChanged(service.Uid, e.Value?.ToString())">
                                                            <option value="">Select a time</option>
                                                            @foreach (var slot in service.ScheduleSlots.TimeSlots)
                                                            {
                                                                <option value="@slot">@slot</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>

                                                @if (selectedDate.HasValue)
                                                {
                                                    <div class="mt-3 small text-muted">
                                                        Selected:
                                                        <strong>@selectedDate.Value.ToString("MMMM dd, yyyy")</strong>
                                                        @if (!string.IsNullOrWhiteSpace(selectedTime))
                                                        {
                                                            <span> at <strong>@selectedTime</strong></span>
                                                        }
                                                    </div>
                                                }

                                                <div class="mt-4 d-flex gap-2 flex-wrap">
                                                    <button class="btn btn-dark rounded-pill px-4"
                                                            disabled="@isAlreadyAdded"
                                                            @onclick="() => AddToAppointment(service)">
                                                        @(isAlreadyAdded ? "Already added" : "Add to appointment")
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 1rem;">
                            <div class="card-body p-4">
                                <h4 class="fw-bold mb-3">Appointment Summary</h4>

                                @if (AppointmentItems.Count == 0)
                                {
                                    <p class="text-muted mb-0">No services added yet.</p>
                                }
                                else
                                {
                                    <div class="d-flex flex-column gap-3">
                                        @foreach (var item in AppointmentItems)
                                        {
                                            <div class="p-3 rounded-4 border bg-light">
                                                <div class="d-flex justify-content-between align-items-start gap-3">
                                                    <div>
                                                        <div class="fw-semibold">@item.ServiceName</div>
                                                        <div class="small text-muted">@item.ServiceUid</div>
                                                        <div class="small mt-2">
                                                            <div><strong>Date:</strong> @item.SelectedDate.ToString("MMMM dd, yyyy (dddd)")</div>
                                                            <div><strong>Time:</strong> @item.SelectedTimeSlot</div>
                                                            <div><strong>Cost:</strong> ₱@item.ServiceCost</div>
                                                        </div>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-danger rounded-pill"
                                                            @onclick="() => RemoveFromAppointment(item.ServiceUid)">
                                                        Remove
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <hr />

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fw-semibold">Total</span>
                                        <span class="fw-bold fs-5">₱@AppointmentItems.Sum(x => x.ServiceCost)</span>
                                    </div>

                                    <button class="btn btn-success w-100 rounded-pill"
                                            @onclick="OpenClientForm">
                                        Continue to client details
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@if (ShowClientForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.55);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h4 class="modal-title fw-bold">Client Information</h4>
                    <button type="button" class="btn-close" @onclick="CloseClientForm"></button>
                </div>

                <div class="modal-body pt-3">
                    <EditForm Model="@ClientInfo" OnValidSubmit="SubmitAppointmentAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Email *</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.Email" />
                                <ValidationMessage For="() => ClientInfo.Email" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Contact Number *</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.ContactNumber" />
                                <ValidationMessage For="() => ClientInfo.ContactNumber" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">First Name *</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.FirstName" />
                                <ValidationMessage For="() => ClientInfo.FirstName" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Last Name *</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.LastName" />
                                <ValidationMessage For="() => ClientInfo.LastName" />
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold">Consumer Information</h5>
                        <p class="text-muted small mb-3">
                            Leave these blank if the consumer is the same as the client.
                            If you fill any one field, all consumer fields become required.
                        </p>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Consumer First Name</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.ConsumerFirstName" />
                                <ValidationMessage For="() => ClientInfo.ConsumerFirstName" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Consumer Last Name</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.ConsumerLastName" />
                                <ValidationMessage For="() => ClientInfo.ConsumerLastName" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Consumer Contact Number</label>
                                <InputText class="form-control" @bind-Value="ClientInfo.ConsumerContactNumber" />
                                <ValidationMessage For="() => ClientInfo.ConsumerContactNumber" />
                            </div>
                        </div>

                        <div class="mt-4 d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" @onclick="CloseClientForm">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-dark rounded-pill px-4" disabled="@IsSubmitting">
                                @(IsSubmitting ? "Submitting..." : "Confirm appointment")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Category { get; set; } = "";

    private bool   IsLoading      = true;
    private bool   IsSubmitting;
    private bool   ShowClientForm;
    private string ErrorMessage   = "";
    private string SuccessMessage = "";

    private BaseSvcStructure?      SelectedService;
    private List<BaseSvcStructure> CurrentCategoryServices = [];

    private ClientInformation ClientInfo = new();

    private readonly Dictionary<string, DateTime?> SelectedDatesByService = new();
    private readonly Dictionary<string, string> SelectedTimesByService = new();

    private readonly List<AppointmentItem> AppointmentItems = [];

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = "";
            SuccessMessage = "";
            SelectedService = null;
            CurrentCategoryServices = [];

            var response = await AppDbOperator.GetServicesAsync();

            CurrentCategoryServices = Category.ToLowerInvariant() switch
            {
                "nails" => response.Nails.Cast<BaseSvcStructure>().ToList(),
                "lashes" => response.Lashes.Cast<BaseSvcStructure>().ToList(),
                _ => []
            };

            SelectedService = CurrentCategoryServices.FirstOrDefault();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetCategoryDisplayName()
    {
        return Category.ToLowerInvariant() switch
        {
            "nails"  => "Nails",
            "lashes" => "Lashes",
            "brows"  => "Brows",
            "spas"   => "Spa",
            _        => "Service"
        };
    }

    private List<DateTime> GetAvailableDates(BaseSvcStructure service, int daysAhead = 60)
    {
        var result = new List<DateTime>();

        if (service.ScheduleSlots?.IsAvailable != true)
            return result;

        if (service.ScheduleSlots.DaySlots is null || service.ScheduleSlots.DaySlots.Count == 0)
            return result;

        var allowedDays = service.ScheduleSlots.DaySlots
            .Select(NormalizeDayName)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var start = GetPhilippineNow().Date;

        for (int i = 0; i < daysAhead; i++)
        {
            var date = start.AddDays(i);
            var dayName = date.DayOfWeek.ToString();

            if (allowedDays.Contains(dayName))
            {
                result.Add(date);
            }
        }

        return result;
    }

    private static string NormalizeDayName(string? rawDay)
    {
        if (string.IsNullOrWhiteSpace(rawDay))
            return "";

        rawDay = rawDay.Trim();

        if (Enum.TryParse<DayOfWeek>(rawDay, true, out var dayOfWeek))
            return dayOfWeek.ToString();

        return rawDay.ToLowerInvariant() switch
        {
            "mon" => DayOfWeek.Monday.ToString(),
            "tue" => DayOfWeek.Tuesday.ToString(),
            "tues" => DayOfWeek.Tuesday.ToString(),
            "wed" => DayOfWeek.Wednesday.ToString(),
            "thu" => DayOfWeek.Thursday.ToString(),
            "thur" => DayOfWeek.Thursday.ToString(),
            "thurs" => DayOfWeek.Thursday.ToString(),
            "fri" => DayOfWeek.Friday.ToString(),
            "sat" => DayOfWeek.Saturday.ToString(),
            "sun" => DayOfWeek.Sunday.ToString(),
            _ => rawDay
        };
    }

    private DateTime? GetSelectedDate(string serviceUid)
    {
        return SelectedDatesByService.TryGetValue(serviceUid, out var value) ? value : null;
    }

    private string GetSelectedDateString(string serviceUid)
    {
        var date = GetSelectedDate(serviceUid);
        return date?.ToString("yyyy-MM-dd") ?? "";
    }

    private string GetSelectedTime(string serviceUid)
    {
        return SelectedTimesByService.TryGetValue(serviceUid, out var value) ? value : "";
    }

    private void OnDateChanged(string serviceUid, string? value)
    {
        if (DateTime.TryParseExact(value, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            SelectedDatesByService[serviceUid] = parsed.Date;
        }
        else
        {
            SelectedDatesByService[serviceUid] = null;
        }
    }

    private void OnTimeChanged(string serviceUid, string? value)
    {
        SelectedTimesByService[serviceUid] = value ?? "";
    }

    private void AddToAppointment(BaseSvcStructure service)
    {
        ErrorMessage = "";
        SuccessMessage = "";

        if (AppointmentItems.Any(x => x.ServiceUid == service.Uid))
        {
            ErrorMessage = "This service is already in the appointment list.";
            return;
        }

        var selectedDate = GetSelectedDate(service.Uid);
        var selectedTime = GetSelectedTime(service.Uid);

        if (!selectedDate.HasValue)
        {
            ErrorMessage = $"Please select a date for {service.Details}.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedTime))
        {
            ErrorMessage = $"Please select a time slot for {service.Details}.";
            return;
        }

        AppointmentItems.Add(new AppointmentItem
        {
            ServiceUid = service.Uid,
            ServiceName = service.Details,
            ServiceDetails = service.Details,
            ServiceCost = Convert.ToInt32(service.Cost),
            SelectedDate = selectedDate.Value,
            SelectedTimeSlot = selectedTime
        });
    }

    private void RemoveFromAppointment(string serviceUid)
    {
        var item = AppointmentItems.FirstOrDefault(x => x.ServiceUid == serviceUid);
        if (item is not null)
        {
            AppointmentItems.Remove(item);
        }
    }

    private void OpenClientForm()
    {
        ErrorMessage = "";
        SuccessMessage = "";

        if (AppointmentItems.Count == 0)
        {
            ErrorMessage = "Please add at least one service first.";
            return;
        }

        ShowClientForm = true;
    }

    private void CloseClientForm()
    {
        ShowClientForm = false;
    }

    private async Task SubmitAppointmentAsync()
    {
        ErrorMessage = "";
        SuccessMessage = "";

        if (AppointmentItems.Count == 0)
        {
            ErrorMessage = "There are no services in the appointment.";
            return;
        }

        try
        {
            IsSubmitting = true;

            ApplyConsumerFallbacks();

            var request = new ClientRequest
            {
                ClientInformation = new ClientInformation
                {
                    ClientBookingId = "",
                    Email = ClientInfo.Email.Trim(),
                    ContactNumber = ClientInfo.ContactNumber.Trim(),
                    FirstName = ClientInfo.FirstName.Trim(),
                    LastName = ClientInfo.LastName.Trim(),
                    ConsumerFirstName = ClientInfo.ConsumerFirstName.Trim(),
                    ConsumerLastName = ClientInfo.ConsumerLastName.Trim(),
                    ConsumerContactNumber = ClientInfo.ConsumerContactNumber.Trim(),
                    BookingDate = GetPhilippineNow()
                },
                ClientServices = AppointmentItems.Select(x => new ClientService
                {
                    ServiceUid = x.ServiceUid,
                    ServiceName = x.ServiceName,
                    ServiceDetails = x.ServiceDetails,
                    ServiceCost = x.ServiceCost,
                    ServiceDate = CombineDateAndTime(x.SelectedDate, x.SelectedTimeSlot)
                }).ToList()
            };

            await AppEmailer.SendEmailAsync(request);

            SuccessMessage = "Your appointment request has been submitted successfully.";
            ShowClientForm = false;

            AppointmentItems.Clear();
            SelectedDatesByService.Clear();
            SelectedTimesByService.Clear();
            ClientInfo = new ClientInformation();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to submit appointment: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ApplyConsumerFallbacks()
    {
        bool hasAnyConsumerValue =
            !string.IsNullOrWhiteSpace(ClientInfo.ConsumerFirstName) ||
            !string.IsNullOrWhiteSpace(ClientInfo.ConsumerLastName) ||
            !string.IsNullOrWhiteSpace(ClientInfo.ConsumerContactNumber);

        if (!hasAnyConsumerValue)
        {
            ClientInfo.ConsumerFirstName = ClientInfo.FirstName;
            ClientInfo.ConsumerLastName = ClientInfo.LastName;
            ClientInfo.ConsumerContactNumber = ClientInfo.ContactNumber;
        }
    }

    private static DateTime CombineDateAndTime(DateTime selectedDate, string timeSlot)
    {
        var startTime = ParseStartTime(timeSlot);
        return selectedDate.Date.Add(startTime);
    }

    private static TimeSpan ParseStartTime(string timeSlot)
    {
        if (string.IsNullOrWhiteSpace(timeSlot))
            return TimeSpan.Zero;

        var normalized = timeSlot.Trim().ToUpperInvariant();

        var rangeMatch = Regex.Match(normalized, @"^\s*(?<start>\d{1,2}(:\d{2})?)\s*-\s*(?<end>\d{1,2}(:\d{2})?)\s*(?<ampm>AM|PM)\s*$");
        if (rangeMatch.Success)
        {
            var start = rangeMatch.Groups["start"].Value;
            var ampm = rangeMatch.Groups["ampm"].Value;

            if (DateTime.TryParseExact(
                $"{start} {ampm}",
                new[] { "h tt", "hh tt", "h:mm tt", "hh:mm tt" },
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var dt))
            {
                return dt.TimeOfDay;
            }
        }

        var directMatch = Regex.Match(normalized, @"(?<start>\d{1,2}(:\d{2})?\s*(AM|PM))");
        if (directMatch.Success &&
            DateTime.TryParseExact(
                directMatch.Groups["start"].Value.Replace("  ", " "),
                new[] { "h tt", "hh tt", "h:mm tt", "hh:mm tt" },
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var parsed))
        {
            return parsed.TimeOfDay;
        }

        return TimeSpan.Zero;
    }

    private static DateTime GetPhilippineNow()
    {
        try
        {
            return TimeZoneInfo.ConvertTimeBySystemTimeZoneId(DateTime.UtcNow, "Asia/Manila");
        }
        catch
        {
            try
            {
                return TimeZoneInfo.ConvertTimeBySystemTimeZoneId(DateTime.UtcNow, "Singapore Standard Time");
            }
            catch
            {
                return DateTime.UtcNow.AddHours(8);
            }
        }
    }

    private sealed class AppointmentItem
    {
        public string ServiceUid { get; set; } = "";
        public string ServiceName { get; set; } = "";
        public string ServiceDetails { get; set; } = "";
        public int ServiceCost { get; set; }
        public DateTime SelectedDate { get; set; }
        public string SelectedTimeSlot { get; set; } = "";
    }
}