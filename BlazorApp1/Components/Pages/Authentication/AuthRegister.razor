@using System.ComponentModel.DataAnnotations
@inject IAppAuthentication Auth

<EditForm Model="model" OnValidSubmit="HandleRegister" class="auth-form">
    <DataAnnotationsValidator />

    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="alert alert-success" role="status">
            @success
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-error" role="alert">
            @error
        </div>
    }

    <div class="form-section">
        <div class="form-group">
            <label for="register-email" class="input-label">Email Address</label>
            <div class="modern-input-shell">
                <input id="register-email"
                       type="email"
                       class="modern-input"
                       @bind="model.Email"
                       @bind:event="oninput"
                       autocomplete="email"
                       placeholder="you@example.com" />
            </div>
            <ValidationMessage For="@(() => model.Email)" class="field-validation" />
        </div>

        <div class="form-group">
            <label for="register-password" class="input-label">Password</label>
            <div class="modern-input-shell">
                <input id="register-password"
                       type="password"
                       class="modern-input"
                       @bind="model.Password"
                       @bind:event="oninput"
                       autocomplete="new-password"
                       placeholder="Create a secure password" />
            </div>
            <ValidationMessage For="@(() => model.Password)" class="field-validation" />
            <div class="helper-text">Use at least 8 characters with a mix of letters, numbers, and symbols.</div>
        </div>

        <div class="form-group">
            <label for="register-confirm-password" class="input-label">Confirm Password</label>
            <div class="modern-input-shell">
                <input id="register-confirm-password"
                       type="password"
                       class="modern-input"
                       @bind="model.ConfirmPassword"
                       @bind:event="oninput"
                       autocomplete="new-password"
                       placeholder="Re-enter your password" />
            </div>
            <ValidationMessage For="@(() => model.ConfirmPassword)" class="field-validation" />
        </div>
    </div>

    <div class="register-meta">
        <p class="terms-text">
            By creating an account, you agree to our
            <a href="/terms" class="form-link">Terms</a>
            and
            <a href="/privacy" class="form-link">Privacy Policy</a>.
        </p>
        <span class="secure-note">Fast and secure account setup</span>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary" disabled="@loading">
            <span class="btn-content">
                @if (loading)
                {
                    <span class="spinner"></span>
                }
                <span>@(loading ? "Creating account..." : "Create Account")</span>
            </span>
        </button>
    </div>

    <ValidationSummary class="validation-summary" />
</EditForm>

@code {
    private RegisterInput model = new();
    private bool loading;
    private string? error;
    private string? success;

    private async Task HandleRegister()
    {
        loading = true;
        error = null;
        success = null;

        try
        {
            await Auth.SignUpAsync(model.Email, model.Password);
            success = "Your account has been created successfully. You can sign in now.";
            model = new RegisterInput();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}