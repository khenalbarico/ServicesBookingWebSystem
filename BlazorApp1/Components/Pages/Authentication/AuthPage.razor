@page "/auth"
@layout AuthLayout

<div class="auth-shell">
    <div class="auth-grid">
        <aside class="auth-brand-panel">
            <div class="brand-overlay"></div>

            <div class="brand-content">
                <span class="brand-badge">Luxury care, simplified booking</span>

                <h1>Book beauty and wellness appointments with ease.</h1>

                <p>
                    Discover nail care, massage therapy, and self-care services in one polished experience.
                </p>

                <div class="brand-points">
                    <div class="brand-point">
                        <span class="point-icon">✦</span>
                        <div>
                            <strong>Instant booking</strong>
                            <span>Reserve your preferred slot in seconds.</span>
                        </div>
                    </div>

                    <div class="brand-point">
                        <span class="point-icon">✦</span>
                        <div>
                            <strong>Trusted professionals</strong>
                            <span>Designed for premium personal care experiences.</span>
                        </div>
                    </div>

                    <div class="brand-point">
                        <span class="point-icon">✦</span>
                        <div>
                            <strong>Elegant scheduling</strong>
                            <span>Simple, modern, and built for mobile-first convenience.</span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <section class="auth-card-panel">
            <div class="auth-card">
                <div class="auth-header">
                    <span class="auth-eyebrow">Welcome</span>
                    <h2>Access your account</h2>
                    <p>Sign in to manage bookings or create a new account to get started.</p>
                </div>

                <div class="auth-tabs" role="tablist" aria-label="Authentication tabs">
                    <button type="button"
                            role="tab"
                            aria-selected="@(activeTab == "login")"
                            aria-controls="auth-panel"
                            class="@GetTabClass("login")"
                            @onclick='() => SetTab("login")'>
                        Sign In
                    </button>

                    <button type="button"
                            role="tab"
                            aria-selected="@(activeTab == "register")"
                            aria-controls="auth-panel"
                            class="@GetTabClass("register")"
                            @onclick='() => SetTab("register")'>
                        Create Account
                    </button>
                </div>

                <div id="auth-panel" class="auth-body" role="tabpanel">
                    @if (activeTab == "login")
                    {
                        <AuthLogin />
                    }
                    else
                    {
                        <AuthRegister />
                    }
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    private string activeTab = "login";

    private void SetTab(string tab) => activeTab = tab;

    private string GetTabClass(string tab)
        => activeTab == tab ? "tab-button active" : "tab-button";
}