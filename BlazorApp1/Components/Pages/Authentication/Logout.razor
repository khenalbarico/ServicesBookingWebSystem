@inject IAppAuthentication AuthService
@inject NavigationManager Nav

<button class="@CssClass"
        @onclick="HandleSignOut"
        disabled="@isLoading"
        aria-busy="@isLoading">

    @if (isLoading)
    {
        <span class="logout-spinner"></span>
    }
    else
    {
        <span class="logout-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M15 16.5L19.5 12L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9.5 12H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M10 4.75H7.75C6.50736 4.75 5.5 5.75736 5.5 7V17C5.5 18.2426 6.50736 19.25 7.75 19.25H10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </span>
    }

    <span class="logout-text">
        @(isLoading ? "Signing out..." : "Log out")
    </span>
</button>

@code {
    [Parameter] public string CssClass { get; set; } = "logout-btn";

    private bool isLoading;

    private async Task HandleSignOut()
    {
        isLoading = true;

        try
        {
            AuthService.SignOut();
            Nav.NavigateTo("/auth", true);
        }
        finally
        {
            isLoading = false;
        }
    }
}